  m_Script: {fileID: 11500000, guid: e6ed070b6287c0949be9bd6211bf0b41, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  slideVoiceClips:
  - {fileID: 8300000, guid: 932b64fe4c80e8e4689d73c9b1f244ab, type: 3}
  - {fileID: 8300000, guid: 5d291f3e8c6474e48a873fe4225880f4, type: 3}
  - {fileID: 8300000, guid: 37c494ca72f9f8648a81d39b4df57c04, type: 3}
  - {fileID: 8300000, guid: 84b1905aea52a9042a28af785a20d9d0, type: 3}
  - {fileID: 8300000, guid: 753ba53c32d92604db8d9c23f7c0d2b9, type: 3}
  - {fileID: 8300000, guid: 9a935bce670961f4ba624dae8c681fc3, type: 3}
  useAudioLengthForTiming: 1
  voiceVolume: 1
  title: GEO FORGE
  subtitle: "L\xF2 R\xE8n H\xECnh H\u1ECDc"
  slides:
  - "Ta l\xE0 Hexa - th\u1EE3 r\xE8n gi\xE0 nh\u1EA5t v\u01B0\u01A1ng qu\u1ED1c.
    V\u01B0\u01A1ng qu\u1ED1c Geometria \u0111\xE3 m\u1EA5t h\u01A1n 100 n\u0103m
    kh\xF4ng c\xF3 th\u1EE3 r\xE8n h\xECnh."
  - "Ng\u01B0\u1EDDi d\xE2n c\u1EA7n th\xF9ng ch\u1EE9a.\r\nHi\u1EC7p s\u0129 c\u1EA7n
    l\u01B0\u1EE1i ki\u1EBFm.\r\nPh\xE1p s\u01B0 c\u1EA7n tinh th\u1EC3 ph\xE9p...\r\nNh\u01B0ng
    kh\xF4ng ai c\xF2n bi\u1EBFt t\xEDnh to\xE1n n\u1EEFa."
  - "Ch\xE1u s\u1EBD l\xE0 th\u1EE3 r\xE8n m\u1EDBi c\u1EE7a v\u01B0\u01A1ng qu\u1ED1c
    Geometria.\nL\xE3o giao x\u01B0\u1EDFng n\xE0y cho ch\xE1u."
  - "X\u01B0\u1EDFng c\xF3 4 th\u1EE9 ch\xEDnh:\n\u0110e r\xE8n - n\u01A1i t\u1EA1o
    h\xECnh\nL\xF2 nung - cho h\xECnh\nV\xF2ng tr\xF2n ma thu\u1EADt - ki\u1EC3m
    tra"
  - "C\xE1ch ch\u01A1i r\u1EA5t \u0111\u01A1n gi\u1EA3n:\u0110\u1ECDc \u0111\u01A1n
    h\xE0ng tr\xEAn b\u1EA3ng. T\xEDnh to\xE1n k\xEDch th\u01B0\u1EDBc. Sau \u0111\xF3
    d\xF9ng c\u1EED ch\u1EC9 ph\xF3ng to, thu nh\u1ECF, c\u1EAFt h\xECnh, \u0111\u1EC3
    t\u1EA1o h\xECnh. \u0110\u1EB7t l\xEAn vong tr\xF2n ma thu\u1EADt \u0111\u1EC3
    th\u1EA9m \u0111\u1ECBnh. H\xE0nh c\xF4ng s\u1EBD nh\u1EADn \u0111\u01B0\u1EE3c
    \u0111\u01A1n h\xE0ng ti\u1EBFp theo"
  - "Kh\xE1ch h\xE0ng \u0111\u1EA7u ti\xEAn s\u1EAFp t\u1EDBi.\nH\xE3y \u0111\u1EBFn
    B\u1EA2NG \u0110\u01A0N H\xC0NG\n\u0111\u1EC3 nh\u1EADn nhi\u1EC7m v\u1EE5 \u0111\u1EA7u
    ti\xEAn!"
  canvasPosition: {x: -9.584, y: 2.8, z: 2.683}
  canvasRotation: {x: 0, y: 270, z: 0}
  canvasSize: {x: 800, y: 500}
  canvasScale: 0.003
